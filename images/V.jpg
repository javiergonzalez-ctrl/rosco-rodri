<!doctype html>
<html lang="en">
  <head>
    <title>Security | Glassdoor</title>
    <meta http-equiv="content-type" content="text/html;charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0caa41" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="https://www.glassdoor.com/favicon.ico" sizes="any" />
    <style type="text/css">
      @font-face {
        font-family: "Glassdoor Sans";
        src: url("data:binary/octet-stream;base64,")
          format("woff2");
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: "Glassdoor Sans";
        src: url("data:binary/octet-stream;base64,")
          format("woff2");
        font-weight: 600;
        font-display: swap;
      }
      body,
      html {
        background: #fff;
        font-family:
          Helvetica Neue,
          HelveticaNeue,
          Helvetica,
          Arial,
          sans-serif;
        font-size: 16px;
        margin: 0;
        padding: 0;
      }
      div,
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      p {
        color: #20262e;
      }
      .header {
        -webkit-box-shadow: inset 0 -1px 0 0 #dee0e3;
        box-shadow: inset 0 -1px 0 0 #dee0e3;
      }
      .header .center {
        height: 45px;
      }
      .header .center:before {
        content: "";
        height: 100%;
        margin-right: -0.25em;
      }
      .header .center:before,
      .logo {
        display: inline-block;
        vertical-align: middle;
      }
      .center {
        margin: 0 auto;
        width: 800px;
      }
      .article-container {
        display: flex;
        gap: 1px;
        margin-top: 32px;
      }

      .article,
      .center {
        box-sizing: border-box;
      }
      .article {
        background-color: #fff;
      }
      .col-article {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
      }
      .text-article {
        text-align: center;
        font-size: 14px;
        font-family: "Glassdoor Sans", sans-serif;
        padding-top: 15px;
      }
      .cferror_details {
        font-family: "Glassdoor Sans", sans-serif;
        font-size: 13px;
        list-style: none;
        background: #f6f7f8;
        border-radius: 8px;
        padding: 16px 20px;
        margin: 20px 0 0;
        color: #4a5568;
        line-height: 1.8;
        overflow-wrap: break-word;
        align-self: stretch;
        box-sizing: border-box;
      }
      .cferror_details strong {
        color: #20262e;
      }
      .captcha-container {
        align-self: stretch;
        text-align: center;
        overflow: hidden;
      }
      .captcha-container iframe {
        max-width: 100%;
      }
      .article-link {
        color: #008050;
      }
      .image-bot {
        padding: 26px 16px;
        width: 360px;
      }
      .body-text {
        margin-top: 0;
        margin-bottom: 20px;
        font-size: 14px;
        font-style: normal;
        font-weight: 400;
        line-height: 20px;
      }
      h1 {
        color: #00060c;
        font-family: "Glassdoor Sans", sans-serif;
        font-size: 24px;
        font-style: normal;
        font-weight: 600;
        line-height: 28px;
        margin-bottom: 32px;
      }
      h2 {
        font-size: 18px;
        font-weight: 400;
        margin: 16px 0;
      }
      @media only screen and (max-width: 767px) {
        .header .center {
          text-align: center;
        }
        .center {
          padding: 0;
          width: 100%;
        }
        .article {
          margin: 0 21.5px;
          max-width: none;
        }
        .col-article {
          gap: 0;
        }
        .article-container {
          flex-direction: column;
          gap: 75.2px;
          margin-top: 7px;
        }
        .body-text {
          margin-bottom: 32px;
        }
        .image-bot {
          padding: 0 32px 32px 32px;
          width: 100%;
          max-width: 360px;
          box-sizing: border-box;
         }
      }
      @media only screen and (min-width: 768px) and (max-width: 1023px) {
        .center {
          margin: 0;
          padding: 0 14px;
          width: 100%;
        }
      }
    </style>
