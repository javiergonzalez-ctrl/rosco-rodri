    <script>
      (function displayTextBasedOnTld() {
        function getTld(domain) {
          if (
            domain.endsWith("glassdoor.fr") ||
            domain.endsWith("fr.glassdoor.be") ||
            domain.endsWith("fr.glassdoor.ch") ||
            domain.endsWith("fr.glassdoor.ca")
          ) {
            return "fr-fr";
          } else if (
            domain.endsWith("glassdoor.de") ||
            domain.endsWith("de.glassdoor.ch") ||
            domain.endsWith("glassdoor.at")
          ) {
            return "de-de";
          } else if (
            domain.endsWith("glassdoor.nl") ||
            domain.endsWith("nl.glassdoor.be")
          ) {
            return "nl-nl";
          } else if (domain.endsWith("glassdoor.es")) {
            return "es-es";
          } else if (
            domain.endsWith("glassdoor.com.ar") ||
            domain.endsWith("glassdoor.com.mx")
          ) {
            return "es-419";
          } else if (domain.endsWith("glassdoor.com.br")) {
            return "pt-br";
          } else if (domain.endsWith("glassdoor.it")) {
            return "it-it";
          } else {
            return "en-us";
          }
        }

        var lang = getTld(window.location.hostname);

        // Update the html lang attribute based on detected language
        var htmlLangMap = {
          "en-us": "en",
          "fr-fr": "fr",
          "de-de": "de",
          "nl-nl": "nl",
          "es-es": "es",
          "es-419": "es",
          "pt-br": "pt",
          "it-it": "it",
        };
        document.documentElement.lang = htmlLangMap[lang] || "en";

        var elements = document.getElementsByClassName("lang");
        for (var i = 0, max = elements.length; i < max; i++) {
          if (elements[i].className.indexOf(lang) === -1)
            elements[i].style.display = "none";
        }
      })();

      // Display page timestamp in UTC
      (function displayTimestamp() {
        var strong = document.createElement("strong");
        strong.textContent = "Timestamp:";
        var el = document.getElementById("page-timestamp");
        el.textContent = " " + new Date().toISOString();
        el.prepend(strong);
      })();

      // Display requested URL
      (function displayRequestedUrl() {
        var strong = document.createElement("strong");
        strong.textContent = "Requested URL:";
        var el = document.getElementById("requested-url");
        el.textContent = " " + window.location.href;
        el.prepend(strong);
      })();

      // Display user agent
      (function displayUserAgent() {
        var strong = document.createElement("strong");
        strong.textContent = "User-Agent:";
        var el = document.getElementById("user-agent");
        el.textContent = " " + navigator.userAgent;
        el.prepend(strong);
      })();
    </script>
